{
  "expo": {
    "name": "AfuChat",
    "slug": "afuchat",
    "version": "2.0.74",
    "orientation": "portrait",
    "icon": "./assets/images/logo.png",
    "scheme": "afuchat",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "jsEngine": "hermes",
    "backgroundColor": "#00BCD4",
    "notification": {
      "icon": "./assets/images/notification-icon-white.png",
      "color": "#00BCD4",
      "iosDisplayInForeground": true
    },
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#00BCD4"
    },
    "android": {
      "package": "com.afuchat.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/afu-symbol.png",
        "backgroundColor": "#00BCD4"
      },
      "googleServicesFile": "./google-services.json",
      "softwareKeyboardLayoutMode": "pan",
      "edgeToEdgeEnabled": false,
      "permissions": [
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.VIBRATE",
        "android.permission.POST_NOTIFICATIONS",
        "android.permission.CAMERA",
        "android.permission.READ_CONTACTS",
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_MEDIA_VIDEO",
        "android.permission.READ_MEDIA_AUDIO",
        "android.permission.READ_MEDIA_VISUAL_USER_SELECTED",
        "android.permission.ACCESS_MEDIA_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.USE_BIOMETRIC",
        "android.permission.USE_FINGERPRINT"
      ],
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "afuchat.com",
              "pathPrefix": "/"
            },
            {
              "scheme": "https",
              "host": "www.afuchat.com",
              "pathPrefix": "/"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        },
        {
          "action": "VIEW",
          "data": [
            {
              "scheme": "afuchat"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ]
    },
    "web": {
      "favicon": "./assets/images/logo.png",
      "bundler": "metro",
      "output": "single",
      "name": "AfuChat",
      "shortName": "AfuChat",
      "description": "Connect, Chat, Discover. Your all-in-one social platform.",
      "themeColor": "#00BCD4",
      "backgroundColor": "#00BCD4"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://afuchat.com"
        }
      ],
      "expo-font",
      "expo-web-browser",
      "@react-native-google-signin/google-signin",
      [
        "expo-image-picker",
        {
          "photosPermission": "AfuChat needs access to your photos to let you share images and videos.",
          "cameraPermission": "AfuChat needs camera access to take photos and record videos."
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "AfuChat uses your location only when the Nearby Friends feature is open, to show AfuChat users near you. Your exact location is never visible to other users.",
          "isIosBackgroundLocationEnabled": false,
          "isAndroidBackgroundLocationEnabled": false
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "AfuChat uses the camera to take photos and videos for stories and messages.",
          "microphonePermission": "AfuChat uses the microphone to record voice messages and video with audio.",
          "recordAudioAndroid": true
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/notification-icon-white.png",
          "color": "#00BCD4",
          "defaultChannel": "default",
          "sounds": [
            "./assets/sounds/notification.wav"
          ]
        }
      ],
      [
        "expo-media-library",
        {
          "photosPermission": "AfuChat uses your photo library to let you save and share media.",
          "savePhotosPermission": "AfuChat saves media to your photo library.",
          "isAccessMediaLocationEnabled": true
        }
      ]
    ],
    "updates": {
      "enabled": false,
      "checkOnLaunch": "NEVER",
      "fallbackToCacheTimeout": 0
    },
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": false
    },
    "extra": {
      "eas": {
        "projectId": "363a3c64-5a90-4aae-86b5-aa54014921ef"
      }
    },
    "owner": "afume"
  }
}
