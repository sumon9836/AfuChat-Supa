[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Mockup Preview Server"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "API Server"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "EAS Build Watch"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "pnpm install --prefer-offline && cd artifacts/mobile && EXPO_NO_LAZY=1 EXPO_PACKAGER_PROXY_URL=https://$REPLIT_EXPO_DEV_DOMAIN EXPO_PUBLIC_DOMAIN=$REPLIT_DEV_DOMAIN EXPO_PUBLIC_REPL_ID=$REPL_ID REACT_NATIVE_PACKAGER_HOSTNAME=$REPLIT_EXPO_DEV_DOMAIN ./node_modules/.bin/expo start --web --port 5000 --clear"
waitForPort = 5000

[[workflows.workflow]]
name = "Mockup Preview Server"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"
isCanvasWorkflow = true

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "pnpm install --prefer-offline && cd artifacts/mockup-sandbox && PORT=8080 BASE_PATH=/__mockup/ ./node_modules/.bin/vite"
waitForPort = 8080

[[workflows.workflow]]
name = "API Server"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "pnpm install --prefer-offline && cd artifacts/api-server && pnpm run build && pnpm run start"
waitForPort = 3000

[[workflows.workflow]]
name = "EAS Build Watch"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = """
cd artifacts/mobile && while true; do
    OUT=$(EXPO_TOKEN=D0ZX0j9_3ko_Rv9ubaB3-9ymgQgQuEE9lJ1jkBZR node_modules/.bin/eas build:view 2275c062-f22e-4412-ae7f-7a6ca5bdc5d0 --json 2>&1 | grep -v '^â' | grep -v '^Found' | grep -v '^It' | grep -v '^Learn' | grep -v '^npm')
    STATUS=$(echo \"$OUT\" | python3 -c \"import sys,json; data=sys.stdin.read(); obj=json.loads(data[data.find('{'):data.rfind('}')+1]); print(obj['status'])\" 2>/dev/null || echo \"IN_PROGRESS\")
    ARTIFACT=$(echo \"$OUT\" | python3 -c \"import sys,json; data=sys.stdin.read(); obj=json.loads(data[data.find('{'):data.rfind('}')+1]); print(obj.get('artifacts',{}).get('buildUrl','none'))\" 2>/dev/null || echo \"none\")
    echo \"$(date -u +%H:%M:%S) status=$STATUS apk=$ARTIFACT\"
    if [ \"$STATUS\" = \"FINISHED\" ] || [ \"$STATUS\" = \"ERRORED\" ] || [ \"$STATUS\" = \"EXPIRED\" ] || [ \"$STATUS\" = \"CANCELLED\" ]; then
      echo \"=== FINAL STATUS: $STATUS ===\"
      echo \"=== APK: $ARTIFACT ===\"
      break
    fi
    sleep 90
  done"""

[workflows.workflow.metadata]
outputType = "console"

[[ports]]
localPort = 3000
externalPort = 3000

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 8080
externalPort = 8080

[[ports]]
localPort = 8081
externalPort = 8081

[deployment]
deploymentTarget = "autoscale"
run = ["bash", "-c", "cd artifacts/api-server && PORT=3000 node --enable-source-maps ./dist/index.mjs & API_PORT=3000 PORT=5000 EXPO_PUBLIC_SUPABASE_URL=https://rhnsjqqtdzlkvqazfcbg.supabase.co EXPO_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InJobnNqcXF0ZHpsa3ZxYXpmY2JnIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NjE2NzA4NjksImV4cCI6MjA3NzI0Njg2OX0.j8zuszO1K6Apjn-jRiVUyZeqe3Re424xyOho9qDl_oY pnpm --filter @workspace/mobile run serve"]
build = ["bash", "-c", "cd artifacts/api-server && pnpm run build && cd ../.. && EXPO_PUBLIC_SUPABASE_URL=https://rhnsjqqtdzlkvqazfcbg.supabase.co EXPO_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InJobnNqcXF0ZHpsa3ZxYXpmY2JnIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NjE2NzA4NjksImV4cCI6MjA3NzI0Njg2OX0.j8zuszO1K6Apjn-jRiVUyZeqe3Re424xyOho9qDl_oY PORT=5000 pnpm --filter @workspace/mobile run build"]

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 120000
