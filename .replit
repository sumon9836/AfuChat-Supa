[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "API Server"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "EAS Build Watch"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "flock -x /tmp/pnpm-install.lock pnpm install --prefer-offline && cd artifacts/mobile && EXPO_NO_LAZY=1 EXPO_PACKAGER_PROXY_URL=https://$REPLIT_EXPO_DEV_DOMAIN EXPO_PUBLIC_DOMAIN=$REPLIT_DEV_DOMAIN EXPO_PUBLIC_REPL_ID=$REPL_ID REACT_NATIVE_PACKAGER_HOSTNAME=$REPLIT_EXPO_DEV_DOMAIN ./node_modules/.bin/expo start --web --port 5000 --clear"
waitForPort = 5000

[[workflows.workflow]]
name = "API Server"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "flock -x /tmp/pnpm-install.lock pnpm install --prefer-offline && cd artifacts/api-server && pnpm run build && pnpm run start"
waitForPort = 3000

[[workflows.workflow]]
name = "EAS Build Watch"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = """
cd artifacts/mobile && export EXPO_TOKEN=D0ZX0j9_3ko_Rv9ubaB3-9ymgQgQuEE9lJ1jkBZR
  echo \"=== Triggering new EAS Android APK build (preview profile) ===\"
  BUILD_JSON=$(node_modules/.bin/eas build --platform android --profile preview --non-interactive --no-wait --json 2>&1)
  BUILD_ID=$(echo \"$BUILD_JSON\" | python3 -c \"import sys,json; data=sys.stdin.read(); arr=json.loads(data[data.find('['):data.rfind(']')+1]); print(arr[0]['id'])\" 2>/dev/null || echo \"$BUILD_JSON\" | python3 -c \"import sys,json; data=sys.stdin.read(); obj=json.loads(data[data.find('{'):data.rfind('}')+1]); print(obj['id'])\" 2>/dev/null || echo \"\")
  if [ -z \"$BUILD_ID\" ]; then
    echo \"=== Build trigger output: ===\"
    echo \"$BUILD_JSON\"
    echo \"=== Falling back to last build ID ===\"
    BUILD_ID=\"f1bf648c-7b14-46aa-9f96-3723e82523f8\"
  fi
  echo \"Build ID: $BUILD_ID\"
  echo \"Track: https://expo.dev/accounts/amkaweesi1/projects/afuchat/builds/$BUILD_ID\"
  while true; do
    RAW=$(node_modules/.bin/eas build:view $BUILD_ID --json 2>&1)
    OUT=$(echo \"$RAW\" | python3 -c \"import sys; lines=[l for l in sys.stdin.read().splitlines() if l.strip().startswith('{')]; print(lines[0] if lines else '')\" 2>/dev/null || echo \"\")
    STATUS=$(echo \"$OUT\" | python3 -c \"import sys,json; print(json.loads(sys.stdin.read())['status'])\" 2>/dev/null || echo \"IN_PROGRESS\")
    ARTIFACT=$(echo \"$OUT\" | python3 -c \"import sys,json; print(json.loads(sys.stdin.read()).get('artifacts',{}).get('buildUrl','none'))\" 2>/dev/null || echo \"none\")
    echo \"$(date -u +%H:%M:%S) status=$STATUS apk=$ARTIFACT\"
    if [ \"$STATUS\" = \"FINISHED\" ] || [ \"$STATUS\" = \"ERRORED\" ] || [ \"$STATUS\" = \"EXPIRED\" ] || [ \"$STATUS\" = \"CANCELLED\" ]; then
      echo \"=== FINAL STATUS: $STATUS ===\"
      echo \"=== APK DOWNLOAD: $ARTIFACT ===\"
      break
    fi
    sleep 90
  done"""

