{
  "installCommand": "pnpm install",
  "buildCommand": "cd artifacts/mobile && export EXPO_PUBLIC_SUPABASE_URL=${NEXT_PUBLIC_SUPABASE_URL:-$EXPO_PUBLIC_SUPABASE_URL} && export EXPO_PUBLIC_SUPABASE_ANON_KEY=${NEXT_PUBLIC_SUPABASE_ANON_KEY:-$EXPO_PUBLIC_SUPABASE_ANON_KEY} && export EXPO_PUBLIC_DOMAIN=${NEXT_PUBLIC_DOMAIN:-${VERCEL_URL:-}} && EXPO_NO_DOTENV=1 node_modules/.bin/expo export --platform web --output-dir dist --clear",
  "outputDirectory": "artifacts/mobile/dist",
  "framework": null,
  "rewrites": [
    {
      "source": "/((?!_expo|assets|favicon\\.ico|favicon\\.png|metadata\\.json|manifest\\.json|logo\\.png|robots\\.txt|sitemap\\.xml|api/).*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/_expo/static/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-XSS-Protection", "value": "1; mode=block" },
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" }
      ]
    }
  ]
}
